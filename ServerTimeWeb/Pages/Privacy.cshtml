@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="glass-card">
                <h1 class="gradient-text mb-4">@ViewData["Title"]</h1>
                <hr style="border-color: var(--glass-border);" class="my-4" />
                <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.6;">
                    This server time demonstration web application is constructed solely for educational purposes. 
                    No private user data is collected, monitored, or transmitted.
                </p>
                <div class="mt-4">
                    <a asp-page="/Index" class="btn btn-secondary-custom">Back to Clock</a>
                </div>
            </div>
        </div>
    </div>
</div>
