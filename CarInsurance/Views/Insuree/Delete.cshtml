@model CarInsurance.Models.Insuree

@{
    ViewData["Title"] = "Delete Quote";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="glass-card border-danger">
                <h2 class="mb-3 text-center gradient-text text-danger">Delete Quote Profile</h2>
                <h5 class="text-center text-muted mb-4">Are you sure you want to delete this profile?</h5>
                <hr style="border-color: var(--glass-border);" />

                <div class="bg-black bg-opacity-25 rounded-3 p-3 mb-4">
                    <table class="table table-borderless text-white mb-0" style="font-size: 0.95rem;">
                        <tr>
                            <td class="text-muted fw-bold" style="width: 40%;">Name:</td>
                            <td>@Model.FirstName @Model.LastName</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold">Email:</td>
                            <td>@Model.EmailAddress</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold">Car Insured:</td>
                            <td>@Model.CarYear @Model.CarMake @Model.CarModel</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold">Monthly Quote:</td>
                            <td style="color: var(--accent-cyan); font-weight: 600;">@string.Format("{0:C}", Model.Quote)</td>
                        </tr>
                    </table>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between">
                        <button type="submit" class="btn btn-danger px-4">Delete Profile</button>
                        <a asp-action="Index" class="btn btn-secondary-custom">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
