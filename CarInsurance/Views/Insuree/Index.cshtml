@model IEnumerable<CarInsurance.Models.Insuree>

@{
    ViewData["Title"] = "Quotes Registry";
}

<div class="container mt-5">
    <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="gradient-text h2 mb-1">Insurance Dashboard</h1>
                <p style="color: var(--text-muted); font-size: 0.95rem;">Manage and view your insurance quotes</p>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-primary-custom">Get New Quote</a>
            </div>
        </div>
        <hr style="border-color: var(--glass-border);" />

        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Car</th>
                        <th>DUI</th>
                        <th class="text-end">Quote</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center" style="color: var(--text-muted); padding: 3rem;">
                                No insurance quotes found. Click "Get New Quote" to start.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FirstName</td>
                                <td>@item.LastName</td>
                                <td>@item.CarYear @item.CarMake @item.CarModel</td>
                                <td>
                                    <span class="badge @(item.DUI ? "bg-danger" : "bg-success")">
                                        @(item.DUI ? "Yes" : "No")
                                    </span>
                                </td>
                                <td class="text-end" style="color: var(--accent-cyan); font-weight: 600;">
                                    @string.Format("{0:C}", item.Quote)
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-1">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
